{
  "schemaVersion": 1,
  "extensionId": "irodori.delta-lake",
  "visibility": "public",
  "version": "0.1.0",
  "connector": {
    "id": "deltaLake.connector",
    "engine": "deltaLake",
    "label": "Delta Lake",
    "aliases": [
      "deltaLake",
      "delta-lake",
      "Delta Lake",
      "Delta",
      "Lake"
    ],
    "defaultPort": 443,
    "wire": "lakehouse",
    "module": "deltaLake.driver",
    "features": [
      "metadata",
      "sql"
    ]
  },
  "connection": {
    "endpoint": {
      "modes": [
        "catalog",
        "objectStorage",
        "jdbc",
        "connectionString"
      ],
      "defaultPort": 443,
        "fields": [
          {
            "id": "catalogType",
            "label": "Catalog type",
            "type": "string",
            "option": "catalogType",
            "default": "file",
            "required": true
          },
          {
            "id": "catalogUri",
            "label": "Catalog URI",
            "type": "uri",
            "option": "catalogUri"
        },
        {
          "id": "warehouse",
            "label": "Warehouse path",
            "type": "string",
            "option": "warehouse"
          },
          {
            "id": "tablePath",
            "label": "Table path",
            "type": "string",
            "option": "tablePath"
          },
          {
            "id": "storageBackend",
            "label": "Storage backend",
            "type": "string",
            "option": "storageBackend",
            "default": "objectStorage"
          },
          {
            "id": "region",
            "label": "Cloud region",
            "type": "string",
            "option": "region"
          },
          {
            "id": "credentialVending",
            "label": "Credential vending",
            "type": "boolean",
            "option": "credentialVending",
            "default": false
          }
        ]
      },
    "authMethods": [
      "none",
      "connectionString",
      "awsSigV4",
      "awsProfile",
      "oauth2",
      "catalogBearerToken",
      "catalogPassword",
      "serviceAccountJson",
      "azureAd",
      "sasToken",
      "customDriverOptions"
    ],
    "tls": "required",
    "transports": "default",
    "optionNamespaces": [
      "lakehouse",
      "deltaLake",
      "aws",
      "catalog",
      "objectStorage"
    ],
    "customDriverOptions": true
  },
  "runtime": {
    "driverLinked": false
  },
  "source": {
    "knowledgeEngineStatus": "recognized_no_connector",
    "adapter": null
  }
}
